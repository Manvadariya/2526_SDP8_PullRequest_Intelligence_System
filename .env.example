# ═══════════════════════════════════════════════════════════
# AgenticPR — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# All values with "REQUIRED" comments MUST be set for production.

# ─── Mode ───────────────────────────────────────────────
# Set PRODUCTION=true for production deployments
# Set DEV_MODE=true for local development with SQLite
PRODUCTION=false
DEV_MODE=true

# ─── Security (REQUIRED in production) ──────────────────
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET=
# GitHub webhook secret — must match your GitHub webhook config
WEBHOOK_SECRET=

# ─── Database ───────────────────────────────────────────
# Default: Postgres (matches docker-compose.yml)
# For local dev with SQLite, set DEV_MODE=true
DATABASE_URL=postgresql+asyncpg://prbot:prbot@localhost:5432/pr_bot_db

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── GitHub ─────────────────────────────────────────────
# Personal access token or GitHub App installation token
GITHUB_TOKEN=

# ─── OAuth (for frontend login) ────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173

# ─── LLM Providers ─────────────────────────────────────
# Primary: Groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Fallback 1: Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Fallback 2: OpenRouter
OPENROUTER_API_KEY=
MODEL=meta-llama/llama-3.1-405b-instruct:free

# Provider selection (groq | gemini | openrouter)
LLM_PROVIDER=groq

# ─── CORS ───────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Worker Configuration ──────────────────────────────
WORKER_CONCURRENCY_FETCH=4
WORKER_CONCURRENCY_ANALYZE=2
WORKER_CONCURRENCY_REVIEW=3
WORKER_CONCURRENCY_PUBLISH=6
MAX_CONCURRENT_PER_REPO=2

# ─── Rate Limiting ─────────────────────────────────────
LLM_RPM_LIMIT=30
GITHUB_API_BUFFER=100

# ─── Docker Checks (optional) ──────────────────────────
ENABLE_DOCKER_CHECKS=false
DOCKER_TIMEOUT=300

# ─── Vector DB ──────────────────────────────────────────
QDRANT_URL=http://localhost:6333
