# ==========================================
# AgenticPR — Environment Configuration
# ==========================================

# === LLM Provider Toggle ===
# Options: "openrouter" or "ollama"
LLM_PROVIDER=ollama

# === OpenRouter Config (when LLM_PROVIDER=openrouter) ===
OPENROUTER_API_KEY=sk-or-xxx
MODEL=meta-llama/llama-3.1-405b-instruct:free

# === Ollama Config (when LLM_PROVIDER=ollama) ===
# Make sure Ollama is running: ollama serve
# And the model is pulled: ollama pull qwen2.5-coder:3b-instruct-q4_K_M
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:3b-instruct-q4_K_M

# === GitHub ===
GITHUB_TOKEN=ghp_xxx
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
WEBHOOK_SECRET=

# === Bitbucket (Atlassian Cloud) ===
# 1. Go to https://bitbucket.org/[workspace]/workspace/settings/api
# 2. Click "OAuth consumers" → "Add consumer"
# 3. Name: AgenticPR, Callback URL: http://localhost:5173/auth/bitbucket/callback
# 4. Permissions: Account (Read), Repositories (Read), Pull requests (Read)
# 5. Copy Key → BITBUCKET_CLIENT_ID, Secret → BITBUCKET_CLIENT_SECRET
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# === GitBucket (self-hosted — optional) ===
GITBUCKET_URL=http://localhost:8080
GITBUCKET_CLIENT_ID=
GITBUCKET_CLIENT_SECRET=

# === Frontend URL (for OAuth redirects) ===
FRONTEND_URL=http://localhost:5173

# === JWT ===
JWT_SECRET=

# === Other (legacy/optional) ===
A4F_API_KEY=
HF_TOKEN=
