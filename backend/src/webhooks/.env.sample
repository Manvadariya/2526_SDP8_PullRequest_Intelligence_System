A4F_API_KEY=
OPENROUTER_API_KEY=
# MODEL=qwen/qwen3-coder:free
# MODEL=stepfun/step-3.5-flash:free
ENABLE_DOCKER_CHECKS=False
# MODEL=qwen/qwen-2.5-coder-32b-instruct
# MODEL=qwen/qwen3-vl-235b-a22b-thinking
# MODEL=z-ai/glm-4.5-air:free
# MODEL=stepfun/step-3.5-flash:free
# MODEL=openai/gpt-oss-20b:free
MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# LLM Provider: "openrouter" or "gemini"
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# === GitHub ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Bitbucket (Atlassian Cloud) ===
# 1. Go to https://bitbucket.org/[workspace]/workspace/settings/api
# 2. Click "OAuth consumers" → "Add consumer"
# 3. Name: AgenticPR, Callback URL: http://localhost:5173/auth/bitbucket/callback
# 4. Permissions: Account (Read), Repositories (Read), Pull requests (Read)
# 5. Copy Key → BITBUCKET_CLIENT_ID, Secret → BITBUCKET_CLIENT_SECRET
BITBUCKET_CLIENT_ID==
BITBUCKET_CLIENT_SECRET=

# === Frontend URL (for OAuth redirects) ===
FRONTEND_URL=http://localhost:5173

# === JWT ===
JWT_SECRET=